{
  "manifest_version": 3,
  "name": "SubstackSaver",
  "version": "1.0.0",
  "description": "Enhance your Substack reading experience with quick-save, progress tracking, and organized bookmarking.",
  "icons": {
    "16": "icons/icon.svg",
    "32": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon.svg",
      "32": "icons/icon.svg",
      "48": "icons/icon.svg"
    },
    "default_title": "SubstackSaver"
  },
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.substack.com/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "tabs",
    "contextMenus",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "*://*.substack.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["dashboard/*", "shared/*"],
      "matches": ["*://*.substack.com/*"]
    }
  ],
  "default_locale": "en"
}
